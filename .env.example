# ── CORS ──────────────────────────────────────────────────────────────────────
# Origens exatas permitidas (separadas por vírgula).
ALLOWED_ORIGINS=https://track-tuneup.lovable.app
# Regex de origens (cobre publicado + previews do Lovable deste projeto). Override
# opcional; o default no código já cobre track-tuneup + previews id-preview/branch.
# ALLOWED_ORIGIN_REGEX=https://(track-tuneup|([a-z0-9-]+--)?3dbebccd-f5c4-4e7a-8278-a1b8acb61c10)\.lovable\.app

# ── Limites de upload / ffmpeg ─────────────────────────────────────────────────
MAX_UPLOAD_MB=200
FFMPEG_TIMEOUT=120

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service_role_key>

# ── Segurança de endpoints internos ────────────────────────────────────────────
# Chave usada pelo endpoint /api/admin/stats (x-admin-key header)
ADMIN_API_KEY=<gere-com-openssl-rand-hex-32>
# Chave usada pelo pg_cron para chamar /api/internal/cleanup (x-internal-key header)
INTERNAL_API_KEY=<gere-com-openssl-rand-hex-32>

# ── Chat AI (Fase 1 — Lovable AI Gateway, OpenAI-compatível) ───────────────────
# Chave gerada/gerenciada pelo projeto Lovable (copie de lá).
LOVABLE_API_KEY=<lovable_api_key>
# Endpoint do gateway (default já aponta pro Lovable AI Gateway).
LOVABLE_API_URL=https://ai.gateway.lovable.dev/v1/chat/completions
# Modelo — confirme o ID no catálogo atual do gateway (ex.: google/gemini-2.5-flash).
LOVABLE_MODEL=google/gemini-2.5-flash
# Timeout (s) da chamada ao gateway. Default: 60
LLM_TIMEOUT=60
# Limite de turnos de chat por cliente por hora. Default: 40
CHAT_RATE_LIMIT=40

# ── pg_cron / cleanup (config via Supabase Vault, não Railway) ─────────────────
# ALTER DATABASE SET é negado no Supabase, então o cron lê do Vault. Crie os dois
# secrets uma vez (SQL editor ou MCP), com os valores reais — NÃO versionados:
#   select vault.create_secret('https://<backend>.up.railway.app', 'tuneup_railway_url');
#   select vault.create_secret('<INTERNAL_API_KEY>',               'tuneup_internal_api_key');
# O tuneup_internal_api_key do Vault deve bater com o INTERNAL_API_KEY do Railway.
