# Origem(ns) permitida(s) no CORS, separadas por vírgula.
# Default: https://track-tuneup.lovable.app
ALLOWED_ORIGINS=https://track-tuneup.lovable.app
# Teto de upload aceito pelo /analyze, em MB. Default: 200
MAX_UPLOAD_MB=200
# Timeout (s) de cada chamada ao ffmpeg. Default: 120
FFMPEG_TIMEOUT=120
